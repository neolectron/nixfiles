{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nixos": {
      "type": "local",
      "command": ["uvx", "mcp-nixos"]
    },
    "arch-linux": {
      "type": "local",
      "command": ["uvx", "arch-ops-server"]
    }
  },
  // Restart tool is only for system-assistant
  "permission": {
    "restart_*": "deny"
  },
  "agent": {
    "system-assistant": {
      "permission": {
        "restart_*": "allow"
      }
    }
  }
}
